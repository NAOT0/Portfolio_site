---
// src/components/Header.astro
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navItems = [
  { name: 'Home', href: `${base}/` },
  { name: 'About', href: `${base}/about/` },
  { name: 'Projects', href: `${base}/projects/` },
  { name: 'News', href: `${base}/news/` },
];
---

<header>
  <nav>
    <a href={navItems[0].href} class="logo">Naoto.K</a>
    <ul>
      {navItems.map(item => (
        <li><a href={item.href}>{item.name}</a></li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header { padding: 1rem 2rem; border-bottom: 1px solid #eee; }
  nav {
    display: flex;
    flex-direction: column; /* スマホでは縦並び */
    gap: 1rem;
    align-items: center;
  }

  /* PCサイズ（640px以上）の時だけ横並びに戻す */
  @media (min-width: 640px) {
    nav {
      flex-direction: row;
      justify-content: space-between;
    }
  }
ul {
    display: flex;
    gap: 1.2rem;
    padding: 0;
    margin: 0;
    list-style: none;
    /* スマホでメニューが溢れたら横スクロールできるようにする */
    overflow-x: auto;
    width: 100%;
    justify-content: center;
    -webkit-overflow-scrolling: touch;
  }
  @media (min-width: 640px) {
    ul {
      width: auto;
      gap: 2rem;
    }
  }
  a { text-decoration: none; color: #333; font-weight: 500; }
  a:hover { color: #0070f3; }
  .logo { font-weight: bold; font-size: 1.2rem; }
</style>