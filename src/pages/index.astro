---
import Layout from '../layouts/Layout.astro';
import { profileData } from '../data/profile';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

// ベースパスを変数に入れておくと楽です
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects.slice(0, 2);
---

<Layout title="Naoto Kagawa | Portfolio">
  <main class="top-container">
    <div class="main-visual-grid">
      
      <section class="bento-item hero">
        <div class="hero-inner">
          <div class="status-indicator">
            <span class="dot"></span>
            Active
          </div>
          <p class="name-en">Naoto Kagawa</p>
          <h1>加川 直澄</h1>
          <p class="description">
            福井大学 工学部。趣味でwebアプリ開発をしています。
          </p>
          <div class="hero-actions">
            <a href={`${base}/about/`} class="btn-main">About Me</a>
            <div class="hero-socials">
              {profileData.links.map((link) => (
                <a href={link.url} target="_blank" rel="noopener noreferrer" title={link.name}>
                  <Icon name={link.icon} class="hero-icon" />
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="bento-item featured-projects">
        <div class="section-header">
          <h3>Featured Projects</h3>
          <a href={`${base}/projects/`} class="view-all-link">All <Icon name="mdi:arrow-right" /></a>
        </div>
        <div class="item-list">
          {featuredProjects.map(p => (
            <a href={`${base}/projects/${p.id}/`} class="list-item project-item">
              <div class="item-content">
                <h4>{p.data.title}</h4>
                <div class="tech-badges">
                  {p.data.tech.slice(0, 2).map(tag => (
                    <span class="badge">{tag}</span>
                  ))}
                </div>
              </div>
              <Icon name="mdi:chevron-right" class="arrow-icon" />
            </a>
          ))}
        </div>
      </section>
    </div>

    <section class="bento-item recent-news">
      <div class="section-header">
        <h3>Latest News</h3>
        <a href={`${base}/news/`} class="view-all">すべて見る →</a>
      </div>

      {latestNews.length > 0 ? (
        <div class="item-list">
          {latestNews.map(post => (
            <article class="list-item news-item">
              <div class="news-meta">
                <time datetime={post.data.publishDate.toISOString()}>
                  {post.data.publishDate.toLocaleDateString('ja-JP')}
                </time>
                <span class="category-tag">{post.data.category}</span>
              </div>
              <a href={`${base}/news/${post.id}/`} class="item-link">
                <h4>{post.data.title}</h4>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <p class="no-data">現在、新しいお知らせはありません。</p>
      )}
    </section>
  </main>
</Layout>

<style>
  .top-container {
    max-width: 1000px;
    margin: 3rem auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* 2カラムレイアウト */
  .main-visual-grid {
    display: grid;
    grid-template-columns: 1.6fr 1.4fr;
    gap: 1.5rem;
  }

  .bento-item {
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 32px;
    padding: 2.5rem;
    transition: all 0.3s ease;
  }

  /* ヒーローセクション */
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-color: transparent;
    background: #f8fafc;
  }
  
  .name-en {
    font-size: var(--fs-sm);
    color: var(--text-muted);
    font-weight: var(--fw-semibold);
    margin-bottom: 0.2rem;
    /* 文字が途切れないよう */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  h1 {
    font-size: var(--fs-5xl);
    margin: 0;
    color: var(--text-primary);
    font-weight: var(--fw-extrabold);
    letter-spacing: -0.02em;
    /* 長い名前もはみ出さない */
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .description {
    margin: 1rem 0 2rem;
    line-height: 1.7;
    color: var(--text-secondary);
    font-size: var(--fs-base);
    /* 意図しない途中改行を防ぐ */
    overflow-wrap: break-word;
    word-break: break-word;
  }
  
  .status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    color: #10b981;
    background: #ecfdf5;
    padding: 0.3rem 0.8rem;
    border-radius: 99px;
    margin-bottom: 1rem;
    width: fit-content;
  }
  .dot { width: 8px; height: 8px; background: #10b981; border-radius: 50%; }

  .btn-main {
    display: inline-block;
    background: var(--text-primary);
    color: white;
    padding: 0.8rem 2rem;
    border-radius: 14px;
    text-decoration: none;
    font-weight: var(--fw-semibold);
    font-size: var(--fs-base);
    transition: all 0.2s;
    white-space: nowrap;
  }
  .btn-main:hover { background: var(--accent); transform: translateY(-2px); }

  /* リスト形式のデザイン共通化 */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .section-header h3 {
    font-size: var(--fs-xs);
    font-weight: var(--fw-extrabold);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }
  .view-all, .view-all-link {
    font-size: var(--fs-sm);
    color: var(--accent);
    text-decoration: none;
    font-weight: var(--fw-bold);
    display: flex;
    align-items: center;
    gap: 0.2rem;
    white-space: nowrap;
  }

  .item-list { display: flex; flex-direction: column; }
  
  .list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    gap: 0.5rem;
  }
  .list-item:last-child { border-bottom: none; padding-bottom: 0; }
  .list-item h4 {
    margin: 0;
    font-size: var(--fs-base);
    font-weight: var(--fw-semibold);
    color: var(--text-primary);
    transition: color 0.2s;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .list-item:hover h4 { color: var(--accent); }

  /* プロジェクト特有のスタイル */
  .project-item .item-content { display: flex; flex-direction: column; gap: 0.5rem; min-width: 0; }
  .tech-badges { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .badge {
    font-size: var(--fs-xs);
    color: var(--text-secondary);
    background: #f1f5f9;
    padding: 2px 8px;
    border-radius: 6px;
    font-weight: var(--fw-semibold);
    white-space: nowrap;
  }
  .arrow-icon { color: #cbd5e1; transition: transform 0.2s; flex-shrink: 0; }
  .project-item:hover .arrow-icon { transform: translateX(4px); color: var(--accent); }

  /* ニュース特有のスタイル */
  .news-item { gap: 1rem; justify-content: flex-start; }
  .news-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .news-meta time {
    font-size: var(--fs-xs);
    color: var(--text-muted);
    font-family: 'Inter', monospace;
    white-space: nowrap;
  }
  .category-tag {
    font-size: var(--fs-xs);
    color: var(--accent);
    background: #eff6ff;
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: var(--fw-bold);
    white-space: nowrap;
  }
  .item-link { flex: 1; text-decoration: none; color: inherit; min-width: 0; }

  /* --- hero actions --- */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .hero-socials {
    display: flex;
    gap: 1rem;
  }

  .hero-icon {
    width: 24px;
    height: 24px;
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .hero-socials a:hover .hero-icon {
    color: var(--text-primary);
    transform: scale(1.1);
  }

  /* ==========================================
     レスポンシブ
     ========================================== */
  @media (max-width: 768px) {
    .main-visual-grid { grid-template-columns: 1fr; }
    .bento-item { padding: 1.75rem; border-radius: 24px; }
    h1 { font-size: var(--fs-4xl); }
    .news-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .top-container { margin: 1.5rem auto; padding: 0 1rem; }
    .bento-item { padding: 1.25rem; border-radius: 20px; }
    h1 { font-size: var(--fs-3xl); }
    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>