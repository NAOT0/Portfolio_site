---
import Layout from '../layouts/Layout.astro';
import { profileData } from '../data/profile';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

// ベースパスを変数に入れておくと楽です
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects.slice(0, 2);
---

<Layout title="Naoto Kagawa | Portfolio">
  <main class="top-container">
    <div class="main-visual-grid">
      
      <section class="bento-item hero">
        <div class="hero-inner">
          <div class="status-indicator">
            <span class="dot"></span>
            Active
          </div>
          <p class="name-en">Naoto Kagawa</p>
          <h1>加川 直澄</h1>
          <p class="description">
            福井大学 工学部。趣味でwebアプリ開発をしています。<br>
          </p>
          <div class="hero-actions">
            <a href={`${base}/about/`} class="btn-main">About Me</a>
            <div class="hero-socials">
              {profileData.links.map((link) => (
                <a href={link.url} target="_blank" rel="noopener noreferrer" title={link.name}>
                  <Icon name={link.icon} class="hero-icon" />
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="bento-item featured-projects">
        <div class="section-header">
          <h3>Featured Projects</h3>
          <a href={`${base}/projects/`} class="view-all-link">All <Icon name="mdi:arrow-right" /></a>
        </div>
        <div class="item-list">
          {featuredProjects.map(p => (
            <a href={`${base}/projects/${p.id}/`} class="list-item project-item">
              <div class="item-content">
                <h4>{p.data.title}</h4>
                <div class="tech-badges">
                  {p.data.tech.slice(0, 2).map(tag => (
                    <span class="badge">{tag}</span>
                  ))}
                </div>
              </div>
              <Icon name="mdi:chevron-right" class="arrow-icon" />
            </a>
          ))}
        </div>
      </section>
    </div>

    <section class="bento-item recent-news">
      <div class="section-header">
        <h3>Latest News</h3>
        <a href={`${base}news/`} class="view-all">すべて見る →</a>
      </div>

      {latestNews.length > 0 ? (
        <div class="item-list">
          {latestNews.map(post => (
            <article class="list-item news-item">
              <div class="news-meta">
                <time datetime={post.data.publishDate.toISOString()}>
                  {post.data.publishDate.toLocaleDateString('ja-JP')}
                </time>
                <span class="category-tag">{post.data.category}</span>
              </div>
              <a href={`${base}/news/${post.id}/`} class="item-link">
                <h4>{post.data.title}</h4>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <p class="no-data">現在、新しいお知らせはありません。</p>
      )}
    </section>
  </main>
</Layout>

<style>
  .top-container {
    max-width: 1000px;
    margin: 4rem auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* 2カラムレイアウト */
  .main-visual-grid {
    display: grid;
    grid-template-columns: 1.6fr 1.4fr;
    gap: 1.5rem;
  }

  .bento-item {
    background: #ffffff;
    border: 1px solid #f1f5f9;
    border-radius: 32px;
    padding: 2.5rem;
    transition: all 0.3s ease;
  }

  /* ヒーローセクション */
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-color: transparent; /* 背景に馴染ませる */
    background: #f8fafc;
  }
  
  .name-en { font-size: 0.9rem; color: #94a3b8; font-weight: 600; margin-bottom: 0.2rem; }
  h1 { font-size: 3.5rem; margin: 0; color: #1e293b; font-weight: 800; letter-spacing: -0.02em; }
  .description { margin: 1rem 0 2rem; line-height: 1.7; color: #64748b; font-size: 1.05rem; }
  
  .status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #10b981;
    background: #ecfdf5;
    padding: 0.3rem 0.8rem;
    border-radius: 99px;
    margin-bottom: 1rem;
    width: fit-content;
  }
  .dot { width: 8px; height: 8px; background: #10b981; border-radius: 50%; }

  .btn-main {
    display: inline-block;
    background: #1e293b;
    color: white;
    padding: 0.8rem 2rem;
    border-radius: 14px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
  }
  .btn-main:hover { background: #0070f3; transform: translateY(-2px); }

  /* リスト形式のデザイン共通化 */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .section-header h3 { font-size: 0.8rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.1em; margin: 0; }
  .view-all, .view-all-link { font-size: 0.8rem; color: #0070f3; text-decoration: none; font-weight: 700; display: flex; align-items: center; gap: 0.2rem; }

  .item-list { display: flex; flex-direction: column; }
  
  .list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    border-bottom: 1px solid #f1f5f9;
    text-decoration: none;
    color: inherit;
  }
  .list-item:last-child { border-bottom: none; padding-bottom: 0; }
  .list-item h4 { margin: 0; font-size: 1rem; font-weight: 600; color: #1e293b; transition: color 0.2s; }
  .list-item:hover h4 { color: #0070f3; }

  /* プロジェクト特有のスタイル */
  .project-item .item-content { display: flex; flex-direction: column; gap: 0.5rem; }
  .tech-badges { display: flex; gap: 0.4rem; }
  .badge {
    font-size: 0.65rem;
    color: #64748b;
    background: #f1f5f9;
    padding: 2px 8px;
    border-radius: 6px;
    font-weight: 600;
  }
  .arrow-icon { color: #cbd5e1; transition: transform 0.2s; }
  .project-item:hover .arrow-icon { transform: translateX(4px); color: #0070f3; }

  /* ニュース特有のスタイル */
  .news-item { gap: 2rem; justify-content: flex-start; }
  .news-meta { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
  .news-meta time { font-size: 0.8rem; color: #94a3b8; font-family: monospace; width: 85px; }
  .category-tag { font-size: 0.65rem; color: #0070f3; background: #eff6ff; padding: 2px 8px; border-radius: 4px; font-weight: 700; }
  .item-link { flex: 1; text-decoration: none; color: inherit; }

  /* レスポンシブ */
  @media (max-width: 850px) {
    .main-visual-grid { grid-template-columns: 1fr; }
    h1 { font-size: 3rem; }
    .news-item { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }

  /* --- 追加するスタイル --- */

.hero-actions {
  display: flex;
  align-items: center; /* 垂直方向を真ん中に揃える */
  gap: 1.5rem;         /* ボタンとアイコン集の距離 */
  margin-top: 2rem;
}

.hero-socials {
  display: flex;
  gap: 1rem;           /* アイコン同士の距離 */
}

.hero-icon {
  width: 24px;
  height: 24px;
  color: #64748b;      /* アイコンの色 */
  transition: all 0.2s ease;
}

.hero-socials a:hover .hero-icon {
  color: #1e293b;      /* ホバー時に少し濃く */
  transform: scale(1.1); /* ほんの少し大きく */
}

/* モバイル対応：画面が狭いときは縦に並べる */
@media (max-width: 640px) {
  .hero-actions {
    flex-direction: column;
    align-items: flex-start;
    gap: 1.2rem;
  }
}
</style>