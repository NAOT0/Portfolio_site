---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | Projects`}>
  <article class="project-detail">
    <header class="detail-header">
      <div class="category">{entry.data.category}</div>
      <h1>{entry.data.title}</h1>
      <div class="meta">
        <span>Project Date: {entry.data.date}</span>
      </div>
      
      <div class="links">
        {entry.data.github && <a href={entry.data.github} target="_blank">GitHub</a>}
        {entry.data.site && <a href={entry.data.site} target="_blank">Live Demo</a>}
      </div>
    </header>

    <div class="markdown-content">
      <Content />
    </div>
        <footer>
      <a href={`${base}/projects/`} class="back-link">← プロジェクト一覧に戻る</a>
    </footer>
  </article>
</Layout>

<style>
  .project-detail {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .detail-header {
    text-align: center;
    margin-bottom: 4rem;
    border-bottom: 1px solid #eee;
    padding-bottom: 2rem;
  }
  .detail-header h1 {
    font-size: var(--fs-4xl);
    font-weight: var(--fw-extrabold);
    color: var(--text-primary);
    margin: 1rem 0;
    overflow-wrap: break-word;
    word-break: break-word;
    line-height: 1.2;
  }
  .category {
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    color: var(--accent);
    background: #eff6ff;
    display: inline-block;
    padding: 3px 10px;
    border-radius: 6px;
  }
  .meta {
    font-size: var(--fs-sm);
    color: var(--text-muted);
    margin-top: 0.5rem;
  }
  
  .links { display: flex; justify-content: center; gap: 1.5rem; margin-top: 1.5rem; flex-wrap: wrap; }
  .links a {
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--accent);
    border-radius: 6px;
    color: var(--accent);
    text-decoration: none;
    font-weight: var(--fw-bold);
    font-size: var(--fs-sm);
    white-space: nowrap;
  }

  /* 本文のスタイル調整 */
  .markdown-content :global(h2) {
    font-size: var(--fs-2xl);
    font-weight: var(--fw-bold);
    margin-top: 3rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--accent);
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .markdown-content :global(p) {
    line-height: 1.8;
    margin-bottom: 1.5rem;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .back-link {
    display: inline-block;
    margin-top: 4rem;
    text-decoration: none;
    color: var(--accent);
    font-weight: var(--fw-bold);
    font-size: var(--fs-sm);
  }

  @media (max-width: 480px) {
    .project-detail { padding: 1.5rem 1rem; }
    .detail-header h1 { font-size: var(--fs-3xl); }
  }
</style>