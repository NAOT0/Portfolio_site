---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// ==========================================
// 1. データ取得とカテゴリー抽出
// ==========================================
const allProjects = await getCollection('projects');
// スキーマで定義された順序を維持しつつ、存在するカテゴリーだけを抽出
const categories = [...new Set(allProjects.map(p => p.data.category))];
---

<Layout title="Projects | Naoto Kagawa">
  <main class="projects-container">
    <header class="page-header">
      <h1 class="page-title">My Projects</h1>
      <p class="page-subtitle">開発、研究、執筆の記録</p>
    </header>

    <nav class="filter-nav">
      <button class="filter-btn active" data-target="all">All</button>
      {categories.map(cat => (
        <button class="filter-btn" data-target={cat}>{cat}</button>
      ))}
    </nav>

    <div class="project-grid">
      {allProjects.map(project => (
        <article class="project-card" data-category={project.data.category}>
          <div class="card-header">
            <span class="category-badge">{project.data.category}</span>
            <span class="date">{project.data.date}</span>
          </div>
          
          <a href={`${base}/projects/${project.id}/`} class="project-link">
            <h2>{project.data.title}</h2>
          </a>
          
          <p class="description">{project.data.description}</p>
          
          <div class="tech-stack">
            {project.data.tech.map(t => <span class="tech-tag">{t}</span>)}
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>

<script>
  // ==========================================
  // 2. フィルタリング・ロジック (JavaScript)
  // ==========================================
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-card') as NodeListOf<HTMLElement>;

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      // ボタンの状態管理
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const target = btn.getAttribute('data-target');

      // カードの表示/非表示を切り替え
      cards.forEach(card => {
        const cat = card.getAttribute('data-category');
        if (target === 'all' || cat === target) {
          card.style.display = 'flex'; // grid内の要素として表示
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  /* --- デザインの概要 --- */
  /* .filter-nav: ボタンの並び。flex-wrapでスマホ対応 */
  /* .filter-btn: アクティブ時にテーマカラー（青）に変化 */
  /* .project-card: Bento風の角丸白背景 */

  .projects-container {
    max-width: 1000px;
    margin: 3rem auto;
    padding: 0 1.5rem;
  }

  .page-header { margin-bottom: 2rem; }
  .page-title {
    font-size: var(--fs-4xl);
    font-weight: var(--fw-extrabold);
    color: var(--text-primary);
    margin: 0;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .page-subtitle {
    font-size: var(--fs-base);
    color: var(--text-muted);
    margin-top: 0.5rem;
  }
  
  .filter-nav { display: flex; gap: 0.5rem; margin-bottom: 3rem; flex-wrap: wrap; }
  
  .filter-btn {
    padding: 0.4rem 1.2rem;
    border-radius: 99px;
    border: 1px solid #e2e8f0;
    background: white;
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    cursor: pointer;
    white-space: nowrap;
  }
  .filter-btn.active { background: var(--accent); color: white; border-color: var(--accent); }

  .project-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .project-card { 
    background: white;
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
  }
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    gap: 0.5rem;
  }
  .date {
    font-size: var(--fs-xs);
    color: var(--text-muted);
    white-space: nowrap;
  }
  .project-link { text-decoration: none; }
  .project-link h2 {
    font-size: var(--fs-xl);
    font-weight: var(--fw-bold);
    color: var(--text-primary);
    margin: 0 0 0.75rem;
    overflow-wrap: break-word;
    word-break: break-word;
    transition: color 0.2s;
  }
  .project-link:hover h2 { color: var(--accent); }
  .description {
    font-size: var(--fs-sm);
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0 0 1rem;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .tech-stack { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: auto; }
  
  .category-badge {
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    color: var(--accent);
    background: #eff6ff;
    padding: 2px 8px;
    border-radius: 6px;
    white-space: nowrap;
  }
  .tech-tag {
    font-size: var(--fs-xs);
    background: #f1f5f9;
    padding: 2px 8px;
    border-radius: 4px;
    color: #475569;
    white-space: nowrap;
  }
  
  @media (max-width: 768px) {
    .project-grid { grid-template-columns: 1fr; }
    .page-title { font-size: var(--fs-3xl); }
  }

  @media (max-width: 480px) {
    .projects-container { padding: 0 1rem; margin: 1.5rem auto; }
  }
</style>