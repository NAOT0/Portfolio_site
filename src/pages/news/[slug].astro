---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 1. ページを生成するためのパス（URL）を定義
export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map((entry) => ({
    // パラメータ名はファイル名の [slug] に合わせますが、値は entry.id を使います
    params: { slug: entry.id }, 
    props: { entry },
  }));
}

// 2. Propsから記事データを取得
const { entry } = Astro.props;

// 3. Markdownをレンダリング（v5以降の新しい書き方）
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | News`}>
  <article class="news-post">
    <header class="post-header">
      <div class="meta">
        <time datetime={entry.data.publishDate.toISOString()}>
          {entry.data.publishDate.toLocaleDateString('ja-JP', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <span class="category-badge">{entry.data.category}</span>
      </div>
      <h1>{entry.data.title}</h1>
      {entry.data.description && <p class="description">{entry.data.description}</p>}
      <hr />
    </header>
    
    <div class="post-content">
      <Content />
    </div>

    <footer>
      <a href={`${base}/news/`} class="back-link">← ニュース一覧に戻る</a>
    </footer>
  </article>
</Layout>

<style>
  .news-post {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .post-header {
    margin-bottom: 3rem;
    text-align: center;
  }
  .meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    color: var(--text-muted);
    font-size: var(--fs-sm);
    flex-wrap: wrap;
  }
  .category-badge {
    background: #e0f2fe;
    color: var(--accent);
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: var(--fw-bold);
    font-size: var(--fs-xs);
  }
  h1 {
    font-size: var(--fs-4xl);
    font-weight: var(--fw-extrabold);
    margin: 0.5rem 0 1.5rem;
    line-height: 1.2;
    overflow-wrap: break-word;
    word-break: break-word;
    color: var(--text-primary);
  }
  .description {
    font-size: var(--fs-lg);
    color: var(--text-secondary);
    font-style: italic;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  hr {
    border: 0;
    border-top: 1px solid #eee;
    margin-top: 2rem;
  }

  /* 記事本文のスタイル */
  .post-content {
    line-height: 1.8;
    font-size: var(--fs-base);
  }
  .post-content :global(h2) {
    font-size: var(--fs-2xl);
    font-weight: var(--fw-bold);
    margin-top: 2.5rem;
    border-left: 4px solid var(--accent);
    padding-left: 1rem;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .post-content :global(p) {
    margin-bottom: 1.5rem;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .post-content :global(strong) {
    color: var(--accent);
  }

  .back-link {
    display: inline-block;
    margin-top: 4rem;
    text-decoration: none;
    color: var(--accent);
    font-weight: var(--fw-bold);
    font-size: var(--fs-sm);
  }
  .back-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .news-post { padding: 1.5rem 1rem; }
    h1 { font-size: var(--fs-3xl); }
    .post-content { font-size: var(--fs-sm); }
  }
/* 画像を囲む枠（figure）の設定 */
.post-image {
  display: flex;
  flex-direction: column;
  align-items: center; /* 横方向の中央揃え */
  justify-content: center;
  margin: 2rem auto;   /* 上下に余白を作り、左右を自動（中央）にする */
  width: 100%;         /* 親要素の幅いっぱいに広げる */
}

/* 画像自体の設定 */
.post-image img {
  display: block;
  margin: 0 auto;      /* 左右中央寄せ */
  max-width: 100%;     /* 画面からはみ出さないように */
  height: auto;        /* アスペクト比を維持 */
}

/* キャプション（figcaption）の設定 */
.post-image figcaption {
  text-align: center;  /* テキストを中央寄せ */
  margin-top: 0.8rem;  /* 画像との間隔 */
  font-size: 0.9rem;
  color: #666;
}

.image-grid {
  display: flex;      /* 横並びにする */
  gap: 1rem;          /* 画像同士の間隔 */
  margin: 2rem 0;
  width: 100%;
}

.image-grid figure {
  flex: 1;            /* 画像を均等な幅にする */
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.image-grid img {
  width: 100%;        /* 親の幅に合わせる */
  height: auto;
  object-fit: cover;  /* 画像の比率が違う場合、綺麗に切り抜く */
  aspect-ratio: 4 / 3; /* 比率を統一したい場合はこれを入れる */
  border-radius: 8px;
}

/* 【重要】スマホ対応：画面が狭いときは縦並びに戻す */
@media (max-width: 640px) {
  .image-grid {
    flex-direction: column;
  }
}
</style>