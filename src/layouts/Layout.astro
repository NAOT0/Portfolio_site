---
// src/layouts/Layout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}/face_icon.svg`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body>
		<Header /> <main>
			<slot /> </main>

		<Footer />
	
	<script>
	// ページ内のすべての <pre> タグ（コードブロック）を取得
	const preTags = document.querySelectorAll("pre");

	preTags.forEach((pre) => {
		// ボタン要素を作成
		const copyButton = document.createElement("button");
		copyButton.className = "copy-button";
		copyButton.textContent = "コピー";

		// <pre> タグの中にボタンを追加
		pre.appendChild(copyButton);

		// ボタンがクリックされた時の処理
		copyButton.addEventListener("click", async () => {
		// <code> タグの中身（実際のコード）を取得
		const code = pre.querySelector("code")?.innerText || "";

		try {
			// クリップボードに書き込む（コピーする）
			await navigator.clipboard.writeText(code);
			
			// コピー成功時の見た目変更
			copyButton.textContent = "コピー完了";
			copyButton.classList.add("copied");

			// 2秒後に元の「コピー」に戻す
			setTimeout(() => {
			copyButton.textContent = "コピー";
			copyButton.classList.remove("copied");
			}, 2000);
		} catch (err) {
			console.error("コピーに失敗しました", err);
		}
		});
	});
	</script>
	</body>
</html>

<style is:global>
	/* ==========================================
	   全ページ共通 デザイントークン & ベーススタイル
	   ========================================== */

	/* コピーボタンの親要素(preタグ)の基準位置を設定 */
/* コードブロック全体の枠 */
	pre {
	position: relative;
	/* ボタンと重ならないよう、右側に広めの余白を作る */
	padding-right: 4rem !important; 
	padding-top: 1.5rem !important; /* 上側にも少し余裕を */
	overflow-x: auto; /* 横スクロールを有効に */
	border-radius: 8px;
	}

	/* コピーボタンのスタイル修正 */
	.copy-button {
	position: absolute;
	top: 8px;
	right: 8px;
	z-index: 10; /* 他の要素より上に表示 */
	
	/* ボタンを目立たせる設定 */
	background-color: rgba(75, 85, 99, 0.9); /* 少し透過させて馴染ませる */
	color: #ffffff;
	border: 1px solid rgba(255, 255, 255, 0.2);
	border-radius: 6px;
	padding: 4px 10px;
	font-size: 0.75rem;
	line-height: 1;
	cursor: pointer;
	
	/* ボタンのテキストを選択されないようにする */
	user-select: none;
	transition: all 0.2s;
	}

	/* ホバー時 */
	.copy-button:hover {
	background-color: rgba(55, 65, 81, 1);
	transform: scale(1.05); /* 少しだけ大きくして反応を示す */
	}

	/* コピー完了時（緑色） */
	.copy-button.copied {
	background-color: #10b981;
	border-color: #059669;
	}
	:root {
		/* カラー */
		--accent: #0070f3;
		--text-primary: #1e293b;
		--text-secondary: #64748b;
		--text-muted: #94a3b8;
		--border: #f1f5f9;

		/* タイポグラフィ スケール */
		--fs-xs:   0.75rem;   /* 12px */
		--fs-sm:   0.875rem;  /* 14px */
		--fs-base: 1rem;      /* 16px */
		--fs-lg:   1.125rem;  /* 18px */
		--fs-xl:   1.25rem;   /* 20px */
		--fs-2xl:  1.5rem;    /* 24px */
		--fs-3xl:  2rem;      /* 32px */
		--fs-4xl:  2.5rem;    /* 40px */
		--fs-5xl:  3rem;      /* 48px */

		/* フォントウェイト */
		--fw-normal: 400;
		--fw-medium: 500;
		--fw-semibold: 600;
		--fw-bold: 700;
		--fw-extrabold: 800;
	}

	*, *::before, *::after {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		/* 日本語はNoto Sans JP、英数字はInterを優先 */
		font-family: 'Inter', 'Noto Sans JP', sans-serif;
		color: var(--text-primary);
		line-height: 1.7;
		-webkit-font-smoothing: antialiased;
		/* スマホで文字サイズが自動変更されるのを防ぐ */
		-webkit-text-size-adjust: 100%;
		text-size-adjust: 100%;
	}

	/* Layoutのmainはpaddingなし、各ページで管理する */
	main {
		min-height: 80vh;
	}

	/* 画像などがはみ出さないように */
	img, video {
		max-width: 100%;
		height: auto;
	}

	/* ulのブラウザデフォルトリセット（各コンポーネントで自由にスタイルできるように） */
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
</style>