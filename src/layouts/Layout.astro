---
// src/layouts/Layout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<Header /> <main>
			<slot /> </main>

		<Footer /> </body>
</html>

<style is:global>
	/* 全ページ共通のスタイル */
	:root {
		--accent: #0070f3;
	}
	body {
		margin: 0;
		font-family: sans-serif;
		color: #333;
		line-height: 1.6;
	}
	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 2rem;
		min-height: 80vh; /* コンテンツが少なくてもフッターを下に押し下げる */
	}
</style>